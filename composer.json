{
    "name": "stonehilt/openapi",
    "description": "Generates OpenAPI Specification for Laravel Applications",
    "keywords": [
        "laravel",
        "openapi",
        "api",
        "documentation",
        "docs",
        "rest",
        "swagger"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anthony Green",
            "email": "openapi@stonehilt.com",
            "homepage": "https://stonehilt.com"
        },
        {
            "name": "Vladimir Yuldashev",
            "email": "misterio92@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "doctrine/dbal": "^2.6|^3.0",
        "laravel/framework": "^12.0",
        "phpdocumentor/reflection-docblock": "^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^5.3|^6.0|^7.0|^9.0|^10.0",
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3",
        "justinrainbow/json-schema": "^5.2"
    },
    "autoload": {
        "psr-4": {
            "StoneHilt\\OpenApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StoneHilt\\OpenApi\\Tests\\": "tests/",
            "Examples\\Petstore\\": "examples/petstore/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "StoneHilt\\OpenApi\\OpenApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "justinrainbow/json-schema": "Required to perform validation (^5.2)"
    },
    "scripts": {
        "test": [
            "@test:style",
            "@test:unit"
        ],
        "test:style": "@fix:style --dry-run",
        "test:unit": "@php vendor/bin/phpunit",
        "fix:style": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --allow-risky=yes --diff --verbose"
    }
}
